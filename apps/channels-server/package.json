{
    "name": "channels-server",
    "version": "1.0.0",
    "description": "Bun runtime wrapper for channel webhooks (Telegram, WhatsApp, etc.)",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "dev:turbo": "bun --watch src/index.ts",
        "start": "bun run dist/index.js",
        "build": "bun build src/index.ts --outdir ./dist --target bun",
        "type-check": "tsc --noEmit"
    },
    "keywords": [],
    "author": "Utkarsh Anand",
    "license": "ISC",
    "dependencies": {
        "@convoform/channels": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@types/bun": "catalog:",
        "typescript": "catalog:"
    },
    "module": "src/index.ts",
    "type": "module",
    "private": true
}